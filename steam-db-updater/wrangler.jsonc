{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "steam-db-updater",
	"main": "src/index.js",
	"compatibility_date": "2026-05-29",
	"observability": {
		"enabled": true
	},
	"triggers": {
		"crons": [
			"* * * * *"
		]
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	]
}